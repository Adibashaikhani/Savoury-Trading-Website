<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  function filterProducts(cat, event) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    document.querySelectorAll('.product-card').forEach(c => {
      c.style.display = (cat === 'all' || c.dataset.cat === cat) ? 'block' : 'none';
    });
  }

  function handleSubmit(e) {
    e.preventDefault();
    const btn = e.target.querySelector('.form-submit');
    btn.textContent = '✓ Enquiry Sent!';
    btn.style.background = '#16a34a';
    setTimeout(() => { btn.textContent = 'Send Enquiry →'; btn.style.background = ''; }, 3000);
  }

  window.addEventListener('scroll', () => {
    document.querySelector('nav').style.boxShadow = window.scrollY > 50
      ? '0 4px 30px rgba(26,79,191,0.14)' : '0 2px 20px rgba(26,79,191,0.06)';
  });
</script>
